"Automatically disabled when \"Delay until consent\" is enabled."
msgstr ""
"Permitir el seguimiento cuando no se encuentra ninguna plataforma de "
"consentimiento. <strong>Nota:</strong> Se desactiva automáticamente cuando "
"se activa \"Retrasar hasta el consentimiento\"."

#: admin/adt-settings-register.php:1066
msgid "Require TCF Consent"
msgstr "Exigir el consentimiento del TCF"

#: admin/adt-settings-register.php:1067
msgid ""
